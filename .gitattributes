# Normalize all text files to LF in the repo.
# Working-tree line endings on Windows still get CRLF via core.autocrlf=true,
# so this is invisible to local edits but stops the LF/CRLF flip from showing
# up as massive diffs on every commit.
* text=auto eol=lf

# Force LF for the dashboard HTML (most-edited, biggest diff offender)
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binary — never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.mov binary
